        </text>
    </l10n>
    
    <multiplayer supported="true"/>
    
    <actions>
        <action name="FREE_CAMERA_TOGGLE" category="ONFOOT" axisType="HALF" ignoreComboMask="false" />
        <action name="FREE_CAMERA_UP" category="ONFOOT" axisType="HALF" ignoreComboMask="false" />
        <action name="FREE_CAMERA_DOWN" category="ONFOOT" axisType="HALF" ignoreComboMask="false" />
        <action name="FREE_CAMERA_SPEED_UP" category="ONFOOT" axisType="HALF" ignoreComboMask="false" />
        <action name="FREE_CAMERA_SPEED_DOWN" category="ONFOOT" axisType="HALF" ignoreComboMask="false" />
        <action name="FREE_CAMERA_PRESET_1" category="ONFOOT" axisType="HALF" ignoreComboMask="false" />
        <action name="FREE_CAMERA_PRESET_2" category="ONFOOT" axisType="HALF" ignoreComboMask="false" />
        <action name="FREE_CAMERA_PRESET_3" category="ONFOOT" axisType="HALF" ignoreComboMask="false" />
        <action name="FREE_CAMERA_PRESET_4" category="ONFOOT" axisType="HALF" ignoreComboMask="false" />
    </actions>

    <inputBinding>
        <actionBinding action="FREE_CAMERA_TOGGLE">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_rctrl KEY_p" />
        </actionBinding>
        <actionBinding action="FREE_CAMERA_UP">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_q" />
            <binding device="GAMEPAD_DEFAULT" input="BUTTON_6" />
        </actionBinding>
        <actionBinding action="FREE_CAMERA_DOWN">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_e" />
            <binding device="GAMEPAD_DEFAULT" input="BUTTON_5" />
        </actionBinding>
        <actionBinding action="FREE_CAMERA_SPEED_UP">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_equals" />
            <binding device="GAMEPAD_DEFAULT" input="BUTTON_17" />
        </actionBinding>
        <actionBinding action="FREE_CAMERA_SPEED_DOWN">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_minus" />
            <binding device="GAMEPAD_DEFAULT" input="BUTTON_19" />
        </actionBinding>
        <actionBinding action="FREE_CAMERA_PRESET_1">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_1" />
            <binding device="GAMEPAD_DEFAULT" input="BUTTON_1" />
        </actionBinding>
        <actionBinding action="FREE_CAMERA_PRESET_2">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_2" />
            <binding device="GAMEPAD_DEFAULT" input="BUTTON_2" />
        </actionBinding>
        <actionBinding action="FREE_CAMERA_PRESET_3">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_3" />
            <binding device="GAMEPAD_DEFAULT" input="BUTTON_3" />
        </actionBinding>
        <actionBinding action="FREE_CAMERA_PRESET_4">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_4" />
            <binding device="GAMEPAD_DEFAULT" input="BUTTON_4" />
        </actionBinding>
    </inputBinding>
</modDesc>
