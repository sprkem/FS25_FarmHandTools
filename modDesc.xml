<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<modDesc descVersion="106">
    <author>YourName</author>
    <version>1.0.0.0</version>
    <iconFilename>icon_TFHtools.dds</iconFilename>
    <title>
        <en>Farm Hand Tools</en>
    </title>
    <description>
        <en><![CDATA[Farm Hand Tools - Free Camera Mode

Press Right Ctrl+P to detach the camera from first person view and enter free-flying camera mode.

Controls in Free Camera Mode:
- WASD: Move horizontally
- Q/E or RB/LB (controller): Move up/down
- +/- or D-Pad Up/Down (controller): Adjust camera speed
- 1-4 or XYAB (controller): Apply speed presets
- Mouse or Right Stick: Look around
- Right Ctrl+P: Return to normal camera

Configure your preferred speed presets in the game settings menu.
All player actions and vehicle switching are disabled while the camera is active.

Perfect for screenshots, exploring the map, or planning your farm layout from a bird's eye view.
]]>
        </en>
    </description>
    
    <extraSourceFiles>
        <sourceFile filename="src/CameraSettings.lua"/>
        <sourceFile filename="src/FreeCamera.lua"/>
        <sourceFile filename="src/main.lua"/>
    </extraSourceFiles>
    
    <l10n>
        <text name="setting_camera_section">
            <en>Free Camera Settings</en>
        </text>
        <text name="setting_camera_cameraMoveSpeed">
            <en>Move Speed</en>
        </text>
        <text name="setting_camera_cameraMoveSpeed_tooltip">
            <en>Base movement speed for the free camera in meters per second</en>
        </text>
        <text name="setting_camera_cameraSprintMultiplier">
            <en>Sprint Multiplier</en>
        </text>
        <text name="setting_camera_cameraSprintMultiplier_tooltip">
            <en>Speed multiplier when holding Shift while moving the free camera</en>
        </text>
        <text name="setting_camera_cameraSpeedPreset1">
            <en>Speed Preset 1</en>
        </text>
        <text name="setting_camera_cameraSpeedPreset1_tooltip">
            <en>Speed preset activated by pressing 1 or A/X button on gamepad</en>
        </text>
        <text name="setting_camera_cameraSpeedPreset2">
            <en>Speed Preset 2</en>
        </text>
        <text name="setting_camera_cameraSpeedPreset2_tooltip">
            <en>Speed preset activated by pressing 2 or B/Circle button on gamepad</en>
        </text>
        <text name="setting_camera_cameraSpeedPreset3">
            <en>Speed Preset 3</en>
        </text>
        <text name="setting_camera_cameraSpeedPreset3_tooltip">
            <en>Speed preset activated by pressing 3 or X/Square button on gamepad</en>
        </text>
        <text name="setting_camera_cameraSpeedPreset4">
            <en>Speed Preset 4</en>
        </text>
        <text name="setting_camera_cameraSpeedPreset4_tooltip">
